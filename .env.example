# Copia este archivo a .env y reemplaza los valores de ejemplo por los
# tuyos antes de desplegar. En Dokploy/Coolify, carga estas mismas variables en
# el panel "Environment" de la app (no necesitas un .env físico en el
# servidor si las defines ahí).

# ---------------------------------------------------------------------
# Generados por ti (uno por deploy, no los reutilices entre proyectos).
# Genera cada uno con: openssl rand -hex 32
# ---------------------------------------------------------------------
SETUP_PASSWORD=4f9a...7f2e8c
OPENCLAW_GATEWAY_TOKEN=9d2e7...1d4a8c

# ---------------------------------------------------------------------
# API keys requeridas por GBrain (embeddings + LLM chunking).
# OpenAI: text-embedding-3-large
# Anthropic: multi-query expansion + chunking (Haiku)
# ---------------------------------------------------------------------
OPENROUTER_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Opcional: solo necesaria si quieres las features de subagente de
# GBrain (takes extract, autopilot dream-cycle), que exigen
# Anthropic-directo y rechazan las llamadas ruteadas por OpenRouter.
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
